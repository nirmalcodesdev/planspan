# Postgres (native systemd on VPS, reached over host network)
PG_HOST=localhost
PG_PORT=5432
PG_DB=shop
PG_USER=planspan
PG_PASSWORD=changeme

# auto_explain log the sidecar tails
PG_LOG_PATH=/var/log/postgresql/postgresql-17-main.log

# SigNoz OTLP (Foundry stack, host network)
OTLP_ENDPOINT=localhost:4317

# service names in SigNoz
DEMOAPP_SERVICE_NAME=shop-api
SIDECAR_SERVICE_NAME=planspan

# sidecar tuning
SCRUB_LITERALS=false   # true redacts quoted literals in filter/query span attrs (PII)
LOCK_POLLER=on
LOCK_POLL_INTERVAL=0.5
WHATIF=on
